# PostgreSQL (with PostGIS extension installed)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sewanee_transit

# JWT signing — generate with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-me-with-a-real-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# CORS — comma-separated origins your frontend will run on
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Cookies — keep secure=false for local dev; flip to true behind HTTPS
COOKIE_SECURE=false
COOKIE_DOMAIN=

ENV=development
